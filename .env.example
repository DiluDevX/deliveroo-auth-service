# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL via AWS RDS or local)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth Service (if validating tokens via external service)
AUTH_SERVICE_URL=http://localhost:3001
AUTH_VALIDATION_MODE=local  # 'local' or 'remote'
AUTH_API_KEY=your-api-key-here

# Mail Service
MAIL_SERVICE_URL=http://localhost:3002
MAILTRAP_USER=your-mailtrap-username
MAILTRAP_PASS=your-mailtrap-password
COMPANY_EMAIL=company@example.com
SUPPORT_EMAIL=support@example.com

# Application URLs
APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
